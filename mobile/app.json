{
  "expo": {
    "name": "AthlynX",
    "slug": "athlynxai",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "athlynxai",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#000000",
    "primaryColor": "#1E90FF",
    "splash": {
      "image": "./assets/splash.png",
      "imageWidth": 200,
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.athlynx.app",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIStatusBarStyle": "UIStatusBarStyleLightContent",
        "UIViewControllerBasedStatusBarAppearance": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "ai.athlynx.app",
      "versionCode": 1,
      "permissions": [
        "POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.MEDIA_IMAGES",
        "android.permission.MEDIA_VIDEO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "notification": {
      "icon": "./assets/notification-icon.png"
    },
    "plugins": [
      "./plugins/withGradleFix",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          },
          "android": {
            "buildArchs": [
              "armeabi-v7a",
              "arm64-v8a"
            ],
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "kotlinVersion": "1.9.24",
            "gradleVersion": "8.10.2",
            "androidGradlePluginVersion": "8.6.1"
          }
        }
      ],
      "./plugins/withCppFix"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://athlynx.ai",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "b1ac40c9-4a90-4f9c-99cd-b1cea06189ad"
      }
    },
    "owner": "cdozier14",
    "jsEngine": "jsc"
  }
}
