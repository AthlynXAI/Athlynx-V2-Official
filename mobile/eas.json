{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle",
        "image": "ubuntu-26.04-jdk-17-ndk-r27b"
      },
      "ios": {
        "distribution": "store",
        "credentialsSource": "remote",
        "image": "macos-tahoe-26.4-xcode-26.4"
      },
      "autoIncrement": true,
      "node": "22.22.2",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://athlynx.ai",
        "EXPO_PUBLIC_SUPABASE_URL": "$EXPO_PUBLIC_SUPABASE_URL",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "$EXPO_PUBLIC_SUPABASE_ANON_KEY",
        "SENTRY_ALLOW_FAILURE": "true",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal",
        "changesNotSentForReview": true
      },
      "ios": {
        "ascApiKeyPath": "./AuthKey_EHRBJCMPF087.p8",
        "ascApiKeyId": "EHRBJCMPF087",
        "ascApiKeyIssuerId": "ba530e88-4441-4029-bc5a-853abab91a91",
        "ascAppId": "6767448150"
      }
    }
  }
}
