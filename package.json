  "scripts": {
    "dev": "NODE_ENV=development tsx watch server/_core/index.ts",
    "build": "vite build && esbuild server/_core/index.ts --platform=node --target=node18 --packages=external --bundle --format=esm --outdir=dist",
    "build:vercel": "node scripts/bundle-doctrine.mjs && vite build --config vite.vercel.config.ts && esbuild server/entry.ts --bundle --platform=node --target=node18 --format=cjs --external:@anthropic-ai/sdk --outfile=api/index.js",
    "identity:check": "node scripts/ensure-git-author.mjs",
    "deploy:preflight": "node scripts/ensure-git-author.mjs && npm run check && npm run build:vercel",
    "bundle:doctrine": "node scripts/bundle-doctrine.mjs",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run",
    "db:push": "drizzle-kit generate && drizzle-kit migrate",
    "build-monitor:selftest": "tsx server/scripts/buildMonitorSelfTest.ts",
    "connector-health:sweep": "python3 scripts/connector-health-sweep.py",
    "connector-health:sweep:julia": "julia scripts/connector_health_sweep.jl"
  },
