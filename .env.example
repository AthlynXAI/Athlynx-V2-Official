# ─────────────────────────────────────────────────────────────────────────
# AthlynX Build 1 — environment variables
# Fill from Google Drive secrets vault. Never commit .env.local.
# ─────────────────────────────────────────────────────────────────────────

# ── Supabase (auth, db, storage) ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Database (Prisma + Neon for PR previews) ─────────────────────────────
DATABASE_URL=
DIRECT_URL=

# ── Sentry (web + mobile) ────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=athlynxai
SENTRY_PROJECT=javascript-react

# ── Stripe ───────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Internal / cron ──────────────────────────────────────────────────────
INTERNAL_ADMIN_TOKEN=
CRON_SECRET=

# ── Vercel ───────────────────────────────────────────────────────────────
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# ── Google Cloud / Drive / Tag Manager / Analytics ───────────────────────
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=

# ── Expo / EAS / Apple ───────────────────────────────────────────────────
EXPO_TOKEN=
ASC_API_KEY_ID=
ASC_API_KEY_ISSUER_ID=
ASC_API_KEY_P8=

# ── Other connectors (filled from Drive as needed) ───────────────────────
# YouTube, Vimeo, Spotify, Pipedrive, Calendly, Zoom, Slack, Monday,
# Airtable, Confluence, Jira, Trello, DocuSign, AWS, Outlook
