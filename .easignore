# EAS Build Archive Exclusions
# Only mobile/ is needed for EAS builds.
# NOTE: mobile/scripts/ must NOT be excluded — eas-build-post-install.sh lives there.

# Version control & CI
.git
.github
.gitignore

# Build artifacts
.next
.turbo
.vercel
.expo
mobile/.expo
coverage
dist
mobile/dist
build
web-build
*.tsbuildinfo
*.log
*.map

# OS / editor
.DS_Store
.env*.local

# Monorepo dirs not needed for mobile build
api/
archive/
audit/
client/
db/
docs/
drizzle/
julia/
legal-documents/
manus-sandbox/
migrations/
public/
python_services/
server/
shared/
vault/
attached_assets/
athlynx-platform/

# Node modules
node_modules
mobile/node_modules

# Native build dirs (generated by prebuild)
android/
ios/
mobile/android/
mobile/ios/

# Media files
*.mov
*.mp4
*.webm
*.pdf
*.zip
